---
import type { CollectionEntry } from 'astro:content';
import Page from '../components/common/Page.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BlogImage from '../components/blog/BlogImage.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, heroAlt, heroCredits, keywords } = Astro.props;

// Import all images from assets directory
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/**/*.{jpeg,jpg,png,gif,webp}', { eager: true });

function formatDate(date: Date) {
    return date.toLocaleDateString('en-GB', {
        day: '2-digit',
        month: '2-digit',
        year: 'numeric'
    });
}

const formattedPublishDate = formatDate(pubDate);
const formattedUpdateDate = updatedDate ? formatDate(updatedDate) : null;

// Get hero image path
const heroImagePath = heroImage ? `/src/assets/${heroImage}` : '/src/assets/julius.jpg';
const resolvedHeroImage = images[heroImagePath]?.default;

// Create SEO image URL
const seoImagePath = heroImage || 'julius.jpg';

// Define custom components for markdown
export const components = {
    img: BlogImage
};
---

<Page
    title={title}
    description={description}
    type="article"
    publishedDate={pubDate}
    modifiedDate={updatedDate}
    image={seoImagePath}
    keywords={keywords}
>
    <article class="prose prose-invert mx-auto max-w-4xl mt-8">
        <div class="mb-8 relative">
            {resolvedHeroImage && (
                <>
                    <Image 
                        src={resolvedHeroImage} 
                        alt={heroAlt || `Hero image for ${title}`}
                        width={1200}
                        height={400}
                        format="webp"
                        quality={80}
                        class="rounded-xl w-full h-[300px] object-cover"
                        loading="eager"
                    />
                    {heroCredits && (
                        <div class="absolute bottom-2 right-2 bg-black/70 px-3 py-1 rounded-full text-sm">
                            Photo by{' '}
                            <a 
                                href={heroCredits.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-primary hover:underline"
                            >
                                {heroCredits.author}
                            </a>
                            {' '}on{' '}
                            <a 
                                href={`https://${heroCredits.source.toLowerCase()}.com`}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-primary hover:underline"
                            >
                                {heroCredits.source}
                            </a>
                        </div>
                    )}
                </>
            )}
        </div>
        <div class="mb-8">
            <h1 class="text-4xl font-bold mb-4">{title}</h1>
            <div class="text-gray-400">
                <time>{formattedPublishDate}</time>
                {formattedUpdateDate && (
                    <div class="italic">
                        Last updated on <time>{formattedUpdateDate}</time>
                    </div>
                )}
            </div>
        </div>
        <div class="prose prose-invert prose-lg">
            <slot />
        </div>
    </article>
</Page>
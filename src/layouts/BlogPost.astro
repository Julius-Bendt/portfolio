---
import type { CollectionEntry } from "astro:content";
import Page from "../components/common/Page.astro";
import { Image } from "astro:assets";
import BlogImage from "../components/blog/BlogImage.astro";
import { getImageByPath } from "../utils/imageUtils";
import { DEFAULT_HERO_IMAGE } from "../constants/site";
import { formatDayMonthYear } from "../utils/formatDate";

type Props = CollectionEntry<"blog">["data"];

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  heroAlt,
  heroCredits,
  keywords,
} = Astro.props;

const formattedPublishDate = formatDayMonthYear(pubDate);
const formattedUpdateDate = updatedDate ? formatDayMonthYear(updatedDate) : null;

const resolvedHeroImage = getImageByPath(heroImage ?? DEFAULT_HERO_IMAGE);

const seoImagePath = heroImage ?? DEFAULT_HERO_IMAGE;

// Define custom components for markdown
export const components = {
  img: BlogImage,
};
---

<Page
  title={title}
  description={description}
  type="article"
  publishedDate={pubDate}
  modifiedDate={updatedDate}
  image={seoImagePath}
  keywords={keywords}
>
  <article class="prose prose-invert mx-auto max-w-4xl mt-8 w-full">
    <div class="mb-8 relative">
      {
        resolvedHeroImage && (
          <>
            <Image
              src={resolvedHeroImage}
              alt={heroAlt || `Hero image for ${title}`}
              width={1200}
              height={400}
              format="webp"
              quality={80}
              class="rounded-xl w-full h-[300px] object-cover"
              loading="eager"
            />
            {heroCredits && (
              <div class="absolute bottom-2 right-2 bg-black/70 px-3 py-1 rounded-full text-sm">
                Photo by{" "}
                <a
                  href={heroCredits.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-primary hover:underline"
                >
                  {heroCredits.author}
                </a>{" "}
                on{" "}
                <a
                  href={`https://${(heroCredits.source ?? "").toLowerCase()}.com`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-primary hover:underline"
                >
                  {heroCredits.source}
                </a>
              </div>
            )}
          </>
        )
      }
    </div>
    <div class="mb-8">
      <h1 class="text-2xl sm:text-4xl font-bold mb-0">{title}</h1>
      <div class="text-gray-400">
        <time>Published on {formattedPublishDate}</time>
        {
          formattedUpdateDate && (
            <div class="italic">
              Last updated on <time>{formattedUpdateDate}</time>
            </div>
          )
        }
      </div>
    </div>
    <div class="prose prose-invert sm:prose-lg max-w-none overflow-x-auto">
      <slot />
    </div>
  </article>
</Page>

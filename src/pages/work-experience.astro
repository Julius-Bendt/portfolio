---
import Page from '../components/common/Page.astro';
import { workExperience } from '../consts';
import WorkExperienceItem from '../components/workExperience/WorkExperienceItem.astro';


---
<Page
    title="Work Experience"
    description="My professional journey as a fullstack developer and DevOps engineer, featuring roles at various companies and projects."
>
	<div class="flex flex-col">
		<h1 class="text-3xl font-bold">Work experience</h1>
	<p class="mb-2">Here are the places I have worked</p>
	
	<div class="grid md:grid-cols-3 grid-cols-1 gap-4">
		{workExperience.map((item) => (
			<WorkExperienceItem 
			name={item.name}
			description={item.description}
			href={item.href}
			yearRange={item.yearRange}
			/>
			))}
	</div>
	</div>
</Page>

---
import Page from "../components/common/Page.astro";
---

<Page title="404 - Page Not Found">
  <div
    class="flex flex-col items-center justify-center min-h-[60vh] text-center"
  >
    <h1 class="text-6xl font-bold text-primary mb-4">404</h1>
    <h2 class="text-2xl font-semibold mb-6">Page Not Found</h2>
    <p class="text-gray-400 mb-8">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a
      href="/"
      class="bg-primary text-black px-6 py-3 rounded-lg font-medium hover:bg-primary/90 transition-colors"
    >
      Return Home
    </a>
  </div>
</Page>

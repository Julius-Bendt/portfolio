---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BlogPost from "../../layouts/BlogPost.astro";
import { getFileDates } from "../../utils/gitDates";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  });

  return posts.map((post) => {
    let dates = { created: post.data.pubDate, modified: post.data.updatedDate };
    try {
      dates = getFileDates(`src/content/blog/${post.id}`);
    } catch {
      // fall back to frontmatter dates if git is unavailable
    }

    const postWithDates = {
      ...post,
      data: {
        ...post.data,
        pubDate: post.data.pubDate || dates.created,
        updatedDate: post.data.updatedDate || dates.modified,
      },
    };

    return {
      params: { slug: post.id },
      props: postWithDates,
    };
  });
}

type Props = CollectionEntry<"blog">;
const post = Astro.props;
const { Content } = await render(post);
---

<BlogPost {...post.data}>
  <Content />
</BlogPost>

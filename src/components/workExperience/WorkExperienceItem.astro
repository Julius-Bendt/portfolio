---
import { formatMonthYear } from "../../utils/formatDate";
import TimelineItem from "../common/TimelineItem.astro";

export interface Props {
  name: string;
  shortDescription: string;
  startDate: Date;
  endDate?: Date;
  description: string;
  href: string | null;
  tags: string[];
  index?: number;
}

const { name, shortDescription, description, href, startDate, endDate, tags, index = Infinity } = Astro.props;

const dateRange = `${formatMonthYear(startDate)} – ${endDate ? formatMonthYear(endDate) : "now"}`;
---

<TimelineItem
  title={name}
  shortDescription={shortDescription}
  dateRange={dateRange}
  badges={tags}
  open={index === 0}
  itemtype="https://schema.org/OrganizationRole"
>
  <p class="text-gray-300" itemprop="description" set:html={description} />
  {
    href && (
      <a
        href={href}
        class="text-primary mt-4 inline-flex items-center group/link hover:underline transition-colors duration-200"
        target="_blank"
        rel="noopener noreferrer"
        itemprop="url"
        data-workplace-link
        data-company-name={name}
      >
        Open workplace website
        <svg
          class="w-4 h-4 ml-2 transform group-hover/link:translate-x-1 transition-transform duration-300"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    )
  }
</TimelineItem>

<script>
  import { capture } from "../../utils/analytics";

  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll<HTMLAnchorElement>("[data-workplace-link]").forEach((link) => {
      if (link.dataset.tracked) return;
      link.dataset.tracked = "true";
      link.addEventListener("click", () => {
        capture("workplace_link_click", {
          company: link.dataset.companyName,
          url: link.href,
        });
      });
    });
  });
</script>

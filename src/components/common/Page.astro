---
import BaseHead from "./BaseHead.astro";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import type { SEOProps } from "../../types/common";
import "../../styles/global.css";

interface Props extends SEOProps {
  class?: string;
}

const { class: className, ...seoMetadata } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <BaseHead {...seoMetadata} />
  </head>
  <body class="bg-body text-gray-100 ">
    <!-- Noise texture overlay -->
    <div class="noise-overlay fixed inset-0 pointer-events-none z-1"></div>

    <!-- Skip to main content link for accessibility -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-100 focus:px-4 focus:py-2 focus:bg-primary focus:text-black focus:rounded-md focus:font-semibold"
    >
      Skip to main content
    </a>
    <div class="relative z-2">
      <Header />
      <div
        class:list={[
          "mx-auto min-h-screen overflow-x-hidden flex flex-col",
          className,
        ]}
      >
        <main
          id="main-content"
          class="mt-16 my-4 flex gap-10 flex-col relative container px-4 mx-auto"
        >
          <slot />
        </main>
        <Footer />
      </div>
    </div>
  </body>
</html>

<style is:global>
  /* Enhanced focus-visible styles for better keyboard navigation */
  *:focus-visible {
    outline: 3px solid var(--color-primary, #ffc107);
    outline-offset: 3px;
    border-radius: 6px;
    transition: outline-offset 0.2s ease;
  }

  /* Specific focus styles for interactive elements */
  a:focus-visible,
  button:focus-visible {
    outline: 3px solid var(--color-primary, #ffc107);
    outline-offset: 4px;
    box-shadow: 0 0 0 4px rgba(255, 193, 7, 0.1);
  }

  /* Focus style for form inputs */
  input:focus-visible,
  textarea:focus-visible,
  select:focus-visible {
    outline: 2px solid var(--color-primary, #ffc107);
    outline-offset: 2px;
    box-shadow: 0 0 0 3px rgba(255, 193, 7, 0.15);
  }

  /* Remove default outline for mouse users */
  *:focus:not(:focus-visible) {
    outline: none;
  }

  /* Screen reader only class */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  /* Ensure focus styles work in dark mode */
  :global(.dark) *:focus-visible {
    outline-color: var(--color-primary-dark, #ffc107);
  }

  :global(.dark) a:focus-visible,
  :global(.dark) button:focus-visible {
    outline-color: var(--color-primary-dark, #ffc107);
    box-shadow: 0 0 0 4px rgba(255, 193, 7, 0.2);
  }

  /* Respect reduced motion preferences */
  @media (prefers-reduced-motion: reduce) {
    *:focus-visible {
      transition: none;
    }
  }

  /* Noise texture overlay */
  .noise-overlay {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.08'/%3E%3C/svg%3E");
    opacity: 1;
    mix-blend-mode: overlay;
  }

  @media (prefers-reduced-motion: reduce) {
    .noise-overlay {
      display: none;
    }
  }
</style>

---
import BaseHead from "./BaseHead.astro";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import type { SEOProps } from '../../types/common';

interface Props extends SEOProps {
  class?: string;
}

const { class: className, ...seoMetadata } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
    <head>
        <BaseHead {...seoMetadata} />
        <script
            defer
            data-domain="jub.dk"
            src="https://jub.dk/js/script.pageview-props.tagged-events.js"
        ></script>
        <script>
            // @ts-ignore
            window.plausible =
                // @ts-ignore
                window.plausible ||
                function () {
                    // @ts-ignore
                    (window.plausible.q = window.plausible.q || []).push(arguments);
                };
        </script>
    </head>
    <body class="bg-body text-gray-100">
        <div class:list={["mx-auto min-h-screen overflow-x-hidden flex flex-col", className]}>
            <Header />
            <main class="mt-16 my-4 flex gap-10 flex-col md:px-[8rem] px-[1rem]">
                <slot />
            </main>
            <Footer />
        </div>
    </body>
</html>
---

---

<div
  id="background-container"
  class="fixed inset-0 overflow-hidden pointer-events-none"
  style="z-index: -1;"
>
  <svg
    id="background-svg"
    width="100%"
    height="100%"
    style="position: absolute; top: 0; left: 0;"
    aria-hidden="true"
  >
    <!-- Shapes will be added here -->
  </svg>
</div>

<script>
  import { ANIMATION } from "../../constants/site";

  // Cached layout values, read outside the rAF loop to avoid forced reflows.
  // Reading document.documentElement.scrollHeight after a DOM write (setAttribute)
  // forces a synchronous layout recalculation. Caching here and updating on resize
  // means the rAF loop can stay write-only.
  let viewportWidth = window.innerWidth;
  let viewportHeight = window.innerHeight;

  window.addEventListener(
    "resize",
    () => {
      viewportWidth = window.innerWidth;
      viewportHeight = window.innerHeight;
    },
    { passive: true }
  );

  class Shape {
    element: SVGElement;
    x: number;
    y: number;
    rotation: number;
    rotationSpeed: number;
    moveSpeed: number;
    size: number;
    originalY: number;
    opacity: number;
    isResetting: boolean;
    shapeType: "cube" | "star" | "triangle";

    constructor(svg: SVGSVGElement, index: number, startAtBottom = false) {
      const sizeRange =
        ANIMATION.cubesBackground.shapeMaxSize -
        ANIMATION.cubesBackground.shapeMinSize;
      this.size =
        Math.random() * sizeRange + ANIMATION.cubesBackground.shapeMinSize;

      // Randomly choose shape type: 70% cubes, 15% stars, 15% triangles
      const rand = Math.random();
      if (rand < 0.7) {
        this.shapeType = "cube";
      } else if (rand < 0.85) {
        this.shapeType = "star";
      } else {
        this.shapeType = "triangle";
      }

      this.element = this.createShape();
      svg.appendChild(this.element);

      // Initial position, use cached values (not live DOM reads)
      this.x = Math.random() * viewportWidth;
      if (startAtBottom) {
        this.y = viewportHeight + this.size;
      } else {
        const section = viewportHeight / 5;
        this.y = index * section + Math.random() * section;
      }

      this.originalY = this.y;
      this.rotation = Math.random() * 360;
      this.rotationSpeed =
        (Math.random() - 0.5) * ANIMATION.cubesBackground.rotationSpeedMax;
      const speedRange =
        ANIMATION.cubesBackground.moveSpeedMax -
        ANIMATION.cubesBackground.moveSpeedMin;
      this.moveSpeed =
        Math.random() * speedRange + ANIMATION.cubesBackground.moveSpeedMin;
      this.opacity = ANIMATION.cubesBackground.shapeOpacity;
      this.isResetting = false;

      this.element.style.fill = "currentColor";
      this.element.style.opacity = this.opacity.toString();
      this.element.style.transition = "opacity 1s ease-in-out";

      this.update(0, 1, false);
    }

    createShape(): SVGElement {
      switch (this.shapeType) {
        case "star":
          return this.createStar();
        case "triangle":
          return this.createTriangle();
        default:
          return this.createCube();
      }
    }

    createCube(): SVGElement {
      const cube = document.createElementNS(
        "http://www.w3.org/2000/svg",
        "rect"
      );
      cube.setAttribute("width", this.size.toString());
      cube.setAttribute("height", this.size.toString());
      cube.setAttribute("rx", (this.size * 0.3).toString());
      return cube;
    }

    createStar(): SVGElement {
      const star = document.createElementNS(
        "http://www.w3.org/2000/svg",
        "polygon"
      );
      const points: string[] = [];
      const outerRadius = this.size / 2;
      const innerRadius = outerRadius * 0.4;
      const centerX = this.size / 2;
      const centerY = this.size / 2;

      for (let i = 0; i < 10; i++) {
        const radius = i % 2 === 0 ? outerRadius : innerRadius;
        const angle = (Math.PI / 5) * i - Math.PI / 2;
        const x = centerX + radius * Math.cos(angle);
        const y = centerY + radius * Math.sin(angle);
        points.push(`${x},${y}`);
      }

      star.setAttribute("points", points.join(" "));
      return star;
    }

    createTriangle(): SVGElement {
      const triangle = document.createElementNS(
        "http://www.w3.org/2000/svg",
        "polygon"
      );
      const height = this.size;
      const width = this.size;
      const points = `${width / 2},0 ${width},${height} 0,${height}`;
      triangle.setAttribute("points", points);
      return triangle;
    }

    reset() {
      this.isResetting = true;
      this.element.style.opacity = "0";

      setTimeout(() => {
        // Use cached values, avoids a forced reflow inside the timeout
        this.y = viewportHeight + this.size;
        this.x = Math.random() * viewportWidth;
        this.originalY = this.y;
        this.isResetting = false;

        setTimeout(() => {
          this.element.style.opacity = this.opacity.toString();
        }, 100);
      }, ANIMATION.cubesBackground.fadeOutDuration);
    }

    // docScrollHeight and prefersReducedMotion are passed in so this method
    // never reads layout properties, all reads happen before the loop in animate().
    update(
      scrollY: number,
      docScrollHeight: number,
      prefersReducedMotion: boolean
    ) {
      if (prefersReducedMotion) {
        this.element.setAttribute(
          "transform",
          `translate(${this.x} ${this.y})`
        );
        return;
      }

      if (this.isResetting) return;

      this.y -= this.moveSpeed;
      this.rotation += this.rotationSpeed;

      if (
        this.y + this.size < ANIMATION.cubesBackground.resetTopThreshold &&
        !this.isResetting
      ) {
        this.reset();
        return;
      }

      // Use pre-read docScrollHeight and cached viewportHeight
      const scrollableHeight = docScrollHeight - viewportHeight;
      const scrollProgress =
        scrollableHeight > 0 ? scrollY / scrollableHeight : 0;
      const parallaxY = scrollY * ANIMATION.cubesBackground.parallaxSpeed;
      const scrollEffect = Math.sin(scrollProgress * Math.PI * 2) * 20;

      const finalY = this.y + parallaxY + scrollEffect;
      const finalX =
        this.x + Math.sin(scrollProgress * Math.PI * 2 + this.x) * 5;

      this.element.setAttribute(
        "transform",
        `translate(${finalX} ${finalY}) rotate(${this.rotation} ${this.size / 2} ${this.size / 2})`
      );
    }
  }

  function initBackground() {
    const svgElement = document.getElementById("background-svg");
    if (!svgElement || !(svgElement instanceof SVGSVGElement)) {
      if (import.meta.env.DEV) {
        console.warn(
          "CubesBackground: #background-svg not found or is not an SVGSVGElement"
        );
      }
      return;
    }

    // Cache prefersReducedMotion once, avoids repeated MediaQueryList allocations
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    const shapes = Array.from(
      { length: ANIMATION.cubesBackground.numberOfShapes },
      (_, i) => new Shape(svgElement, i)
    );

    let lastScrollY = window.scrollY;
    let ticking = false;
    let animationFrameId: number;
    let isRunning = true;
    let isVisible = true;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          isVisible = entry.isIntersecting;
          if (isVisible && !prefersReducedMotion) {
            animate();
          } else if (animationFrameId) {
            cancelAnimationFrame(animationFrameId);
          }
        });
      },
      { threshold: 0 }
    );

    const container = document.getElementById("background-container");
    if (container) {
      observer.observe(container);
    }

    function animate() {
      if (!isRunning || !isVisible || prefersReducedMotion) return;
      // Read scrollHeight ONCE before the loop so no shape.update() call triggers
      // a forced reflow by reading layout after a sibling's DOM write.
      const docScrollHeight = document.documentElement.scrollHeight;
      shapes.forEach((shape) =>
        shape.update(lastScrollY, docScrollHeight, prefersReducedMotion)
      );
      animationFrameId = requestAnimationFrame(animate);
    }

    const scrollHandler = () => {
      lastScrollY = window.scrollY;
      if (!ticking && !prefersReducedMotion) {
        window.requestAnimationFrame(() => {
          const docScrollHeight = document.documentElement.scrollHeight;
          shapes.forEach((shape) =>
            shape.update(lastScrollY, docScrollHeight, prefersReducedMotion)
          );
          ticking = false;
        });
        ticking = true;
      }
    };

    window.addEventListener("scroll", scrollHandler, { passive: true });

    const cleanup = () => {
      isRunning = false;
      if (animationFrameId) {
        cancelAnimationFrame(animationFrameId);
      }
      window.removeEventListener("scroll", scrollHandler);
      observer.disconnect();
    };

    document.addEventListener("astro:before-swap", cleanup);
    window.addEventListener("beforeunload", cleanup);

    if (!prefersReducedMotion) {
      animate();
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initBackground);
  } else {
    initBackground();
  }
</script>

<style is:global>
  #background-svg rect,
  #background-svg polygon {
    fill: var(--color-primary);
  }

  @media (prefers-color-scheme: dark) {
    #background-svg rect,
    #background-svg polygon {
      fill: var(--color-primary-dark, var(--color-primary));
    }
  }
</style>

---
import { Image } from 'astro:assets';

import type { PortfolioItemProps } from '../../types/common';
export interface Props extends PortfolioItemProps {}

const { name, description, href, image, status = 'completed' } = Astro.props;

const statusColors = {
    'completed': 'bg-green-500',
    'in-progress': 'bg-yellow-500',
    'archived': 'bg-blue-500'
};

const statusText = {
    'completed': 'Completed',
    'in-progress': 'In Progress',
    'archived': 'Archived / Finished'
};
---

<article 
    class="bg-bodyAccent p-3 rounded-md flex flex-col gap-1 transform hover:-translate-y-1 transition-all duration-300 ease-in-out hover:shadow-lg"
    itemscope 
    itemtype="https://schema.org/Project"
>
    <div class="relative">
        <Image 
            src={`/assets/portfolio/${image}`}
            alt={`Screenshot or preview of ${name}`}
            width={800}
            height={600}
            class="rounded-md w-full h-[40vh] object-cover"
            loading="lazy"
            itemprop="image"
        />
        <span 
            class={`absolute top-2 right-2 px-2 py-1 rounded-full text-white text-sm ${statusColors[status]}`}
        >
            {statusText[status]}
        </span>
    </div>

    <h2 
        class="text-xl font-bold mt-2" 
        itemprop="name"
    >
        {name}
    </h2>

    <p 
        class="text-gray-300 flex-grow"
        itemprop="description"
        set:html={description}
    />

    {href && (
        <a 
            href={href}
            class="text-primary mt-4 inline-flex items-center group hover:underline"
            target="_blank"
            rel="noopener noreferrer"
            itemprop="url"
        >
            View Project
            <svg 
                class="w-4 h-4 ml-2 transform group-hover:translate-x-1 transition-transform" 
                fill="none" 
                stroke="currentColor" 
                viewBox="0 0 24 24"
            >
                <path 
                    stroke-linecap="round" 
                    stroke-linejoin="round" 
                    stroke-width="2" 
                    d="M9 5l7 7-7 7"
                />
            </svg>
        </a>
    )}
</article>
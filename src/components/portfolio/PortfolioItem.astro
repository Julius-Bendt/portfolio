---
import { Image } from "astro:assets";
import { validateAltText } from "../../utils/imageValidation";
import { getImageByPath } from "../../utils/imageUtils";
import type { PortfolioItemProps } from "../../types/common";
import TimelineItem from "../common/TimelineItem.astro";
import ExternalLink from "../common/ExternalLink.astro";

export interface Props extends PortfolioItemProps {
  shortDescription: string;
  tags: string[];
  index?: number;
}

const { name, shortDescription, description, href, image, tags, index = Infinity } = Astro.props;

const resolvedImage = getImageByPath(`portfolio/${image}`);
const altText = validateAltText(`Screenshot or preview of ${name}`, image);
const loadingStrategy = index < 3 ? "eager" : "lazy";
---

<TimelineItem
  title={name}
  shortDescription={shortDescription}
  badges={tags}
  open={index === 0}
  itemtype="https://schema.org/Project"
>
  <div class="flex flex-col md:flex-row gap-4">
    {
      resolvedImage ? (
        <div class="relative md:w-52 shrink-0 overflow-hidden rounded-md">
          <div class="absolute inset-0 bg-bodyAccent animate-pulse blur-sm image-placeholder z-[1]" />
          <Image
            src={resolvedImage}
            alt={altText}
            width={400}
            height={300}
            class="rounded-md w-full aspect-video object-contain bg-bodyAccent/50 portfolio-image"
            loading={loadingStrategy}
            decoding="async"
            itemprop="image"
          />
        </div>
      ) : (
        <div class="md:w-52 shrink-0 bg-bodyAccent aspect-video flex items-center justify-center rounded-md">
          <span class="text-foreground-muted text-sm">No image</span>
        </div>
      )
    }
    <div class="flex flex-col gap-2">
      <p class="text-foreground-secondary" itemprop="description" set:html={description} />
      {
        href && (
          <ExternalLink
            href={href}
            class="mt-2"
            itemprop="url"
            data-project-link
            data-project-name={name}
          >
            View Project
          </ExternalLink>
        )
      }
    </div>
  </div>
</TimelineItem>

<script>
  function initImagePlaceholders() {
    const images = document.querySelectorAll(".portfolio-image");
    images.forEach((img) => {
      if (!(img instanceof HTMLImageElement)) return;
      const placeholder = img.parentElement?.querySelector(".image-placeholder");
      if (!placeholder) return;
      if (img.complete) {
        placeholder.classList.add("opacity-0");
        setTimeout(() => placeholder.remove(), 300);
      } else {
        img.addEventListener("load", () => {
          placeholder.classList.add("transition-opacity", "duration-300", "opacity-0");
          setTimeout(() => placeholder.remove(), 300);
        });
      }
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initImagePlaceholders);
  } else {
    initImagePlaceholders();
  }

  document.addEventListener("astro:page-load", initImagePlaceholders);
</script>

<script>
  import { capture } from "../../utils/analytics";

  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll<HTMLAnchorElement>("[data-project-link]").forEach((link) => {
      if (link.dataset.tracked) return;
      link.dataset.tracked = "true";
      link.addEventListener("click", () => {
        capture("project_link_click", {
          project: link.dataset.projectName,
          url: link.href,
        });
      });
    });
  });
</script>
